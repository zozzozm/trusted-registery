{
  "name": "mpc-node-registry",
  "version": "1.0.0",
  "description": "MPC Custody Node Registry — Signed JSON over GitHub",
  "private": true,
  "scripts": {
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc",
    "setup": "ts-node scripts/setup.ts",
    "keygen": "ts-node scripts/keygen.ts",
    "sign": "ts-node scripts/sign.ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "helmet": "^7.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^6.0.0"
  },
  "jest": {
    "moduleFileExtensions": ["js","json","ts"],
    "rootDir": ".",
    "testRegex": ".*\\.test\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "testEnvironment": "node"
  }
}
