PORT=3000
NODE_ENV=development
REGISTRY_ID=dev-custody-v1
EXPIRY_SECONDS=604800
MIN_SIGNATURES=2

# Admin public keys (generate with: npm run keygen)
ADMIN_KEY_0_PUB=your_hex_ed25519_public_key_here
ADMIN_KEY_1_PUB=your_hex_ed25519_public_key_here
ADMIN_KEY_2_PUB=your_hex_ed25519_public_key_here

# DEV ONLY — never in production
DEV_ADMIN_KEY_0_PRIV=your_hex_ed25519_private_key_here
DEV_ADMIN_KEY_1_PRIV=your_hex_ed25519_private_key_here
DEV_ADMIN_KEY_2_PRIV=your_hex_ed25519_private_key_here

REGISTRY_FILE=./data/registry.json
