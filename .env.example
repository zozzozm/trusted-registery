PORT=3000
NODE_ENV=development
REGISTRY_ID=custody-wallet
EXPIRY_SECONDS=604800

# ── SYSTEM_ADMIN (required, min 3 Ethereum addresses) ─────────────────────
ADMIN_ADDRESS_0=0x...
ADMIN_ADDRESS_1=0x...
ADMIN_ADDRESS_2=0x...

# ── POLICY_COMPLIANCE (optional) ──────────────────────────────────────────
# POLICY_COMPLIANCE_ADDRESS_0=0x...
# POLICY_COMPLIANCE_ADDRESS_1=0x...

# ── TREASURY_OPS (optional) ───────────────────────────────────────────────
# TREASURY_OPS_ADDRESS_0=0x...

# ── AUDIT_OBSERVER (optional) ─────────────────────────────────────────────
# AUDIT_OBSERVER_ADDRESS_0=0x...

REGISTRY_FILE=./data/registry.json
